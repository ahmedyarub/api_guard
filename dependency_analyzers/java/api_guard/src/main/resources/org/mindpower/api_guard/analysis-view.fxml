<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.mindpower.api_guard.AnalysisController"
      prefHeight="600.0"
      prefWidth="800.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Button fx:id="analyzeButton" text="Analyze!" onAction="#onAnalyzeButtonClick"/>
    <Button fx:id="openButton" text="Open" onAction="#onOpenButtonClick"/>
    <ListView fx:id="projectsList"/>
</VBox>
